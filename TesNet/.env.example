APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Production Paystack: use your public HTTPS origin (e.g. https://portal.tesnet.local)
APP_FORCE_HTTPS=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tesnet
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Default admin (run php artisan db:seed after changing)
ADMIN_NAME="TesNet Admin"
ADMIN_PHONE=
ADMIN_PASSWORD=
ADMIN_EMAIL=admin@tesnet.local
ADMIN_DEVICE_LIMIT=5

PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
# Paystack API only — do NOT put your ngrok or site URL here
PAYSTACK_BASE_URL=https://api.paystack.co
# Paystack rejects @tesnet.local — use a normal domain (example.com is fine for test)
PAYSTACK_CUSTOMER_EMAIL_DOMAIN=example.com
# Webhook URL (paste in Paystack dashboard only): {APP_URL}/portal/payments/webhook — see docs/PAYSTACK.md

# Custom data slider (GH¢) — interpolates between fixed packages; extrapolates below/above
CUSTOM_DATA_SLIDER_MIN_AMOUNT=1
CUSTOM_DATA_SLIDER_MAX_AMOUNT=100
CUSTOM_DATA_SPEED_MBPS=60

# Student support contact (shown on portal Support page)
SUPPORT_PHONE=
SUPPORT_EMAIL=
SUPPORT_HOURS="Monday–Friday, 8:00 AM – 5:00 PM"

MIKROTIK_LOGIN_URL=http://192.168.88.1/login

MIKROTIK_API_ENABLED=false
MIKROTIK_API_HOST=
MIKROTIK_API_PORT=
MIKROTIK_API_USER=
MIKROTIK_API_PASSWORD=
MIKROTIK_API_SSL=false
