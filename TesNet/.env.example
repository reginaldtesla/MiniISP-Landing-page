APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Production Paystack: use your public HTTPS origin (e.g. https://portal.tesnet.local)
APP_FORCE_HTTPS=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
# Production: use daily for automatic log rotation
# LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tesnet
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# Production: set true so session payloads (including encrypted Wi-Fi credentials) are not stored in plain text
SESSION_ENCRYPT=false
SESSION_PATH=/
# Leave empty for 192.168.88.2 — do NOT set SESSION_DOMAIN=192.168.88.2 (causes 419)
# SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false
# true when using ngrok or HTTPS reverse proxy (with APP_URL matching that host)
TRUST_PROXIES=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Default admin (run php artisan db:seed after changing)
ADMIN_NAME="TesNet Admin"
ADMIN_PHONE=
ADMIN_PASSWORD=
ADMIN_EMAIL=admin@tesnet.local
ADMIN_DEVICE_LIMIT=5
# Restrict /admin to LAN IPs (comma-separated). Empty = allow all.
# ADMIN_ALLOWED_IPS=192.168.88.0/24,127.0.0.1
ADMIN_MIN_PASSWORD_LENGTH=12
ADMIN_IDLE_LOGOUT_MINUTES=5
LOGIN_RATE_LIMIT=10
LOGIN_RATE_DECAY_MINUTES=1
REGISTER_RATE_LIMIT=5

# Scheduled backups (requires cron: php artisan schedule:run)
TESNET_BACKUP_ENABLED=true
TESNET_BACKUP_PATH=
TESNET_BACKUP_RETAIN_DAYS=14
TESNET_DISK_FREE_PERCENT_MIN=10
TESNET_RADIUS_STALE_HOURS=6
# Dashboard skips router API; full sync runs on Connect + cron (seconds between repeat syncs)
TESNET_QUOTA_SYNC_COOLDOWN=45
TESNET_PORTAL_CONNECTED_CACHE=15
# Per-purchase MikroTik users (tn-{id}) — one hidden hotspot login per payment
TESNET_PER_PURCHASE_HOTSPOT=true
TESNET_HOTSPOT_PROFILE_PACKAGE=tesnet-pkg
TESNET_HOTSPOT_PROFILE_CUSTOM=tesnet-custom
TESNET_STUDENT_DEVICE_LIMIT=1
TESNET_HOTSPOT_SHARED_USERS=1
TESNET_HOTSPOT_CLEANUP_DAYS=30

PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
# Paystack API only — do NOT put your ngrok or site URL here
PAYSTACK_BASE_URL=https://api.paystack.co
# Paystack rejects @tesnet.local — use a normal domain (example.com is fine for test)
PAYSTACK_CUSTOMER_EMAIL_DOMAIN=example.com
# Webhook URL (paste in Paystack dashboard only): {APP_URL}/portal/payments/webhook — see docs/PAYSTACK.md

# Custom data slider (GH¢) — interpolates between fixed packages; extrapolates below/above
CUSTOM_DATA_SLIDER_MIN_AMOUNT=1
CUSTOM_DATA_SLIDER_MAX_AMOUNT=100
CUSTOM_DATA_SPEED_MBPS=60

# Student support contact (shown on portal Support page)
SUPPORT_PHONE=
SUPPORT_EMAIL=
SUPPORT_HOURS="Monday–Friday, 8:00 AM – 5:00 PM"

# Serve fonts, Material icons, CSS, and JS from public/assets/portal (run npm run build:offline)
PORTAL_USE_OFFLINE_ASSETS=true

MIKROTIK_LOGIN_URL=http://192.168.88.1/login
# Where students land after Connect (MikroTik dst=). Use LAN portal URL, not ngrok, for hotspot.
MIKROTIK_POST_LOGIN_URL=http://192.168.88.2/portal/dashboard

# Required for accurate dashboard data usage when radacct is slow or empty
MIKROTIK_API_ENABLED=false
MIKROTIK_API_HOST=192.168.88.1
MIKROTIK_API_PORT=
MIKROTIK_API_USER=
MIKROTIK_API_PASSWORD=
MIKROTIK_API_SSL=false
MIKROTIK_API_TIMEOUT=2
